<Window x:Class="ShellTaskbar.TaskbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#1E1E1E"
        Height="40"
        Opacity="0">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- App buttons -->
        <ItemsControl Grid.Column="0" Name="AppButtonsPanel" VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Margin="4,0"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Name}"
                            Tag="{Binding}"
                            Click="AppButton_Click"
                            Margin="4,0,0,0"
                            Padding="12,0"
                            Height="30"
                            Foreground="White"
                            Background="#3A3A3A"
                            BorderBrush="#555"
                            BorderThickness="1"
                            Cursor="Hand">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Restore"  Tag="{Binding}" Click="ContextRestore_Click"/>
                                <MenuItem Header="Minimize" Tag="{Binding}" Click="ContextMinimize_Click"/>
                                <MenuItem Header="Maximize" Tag="{Binding}" Click="ContextMaximize_Click"/>
                                <Separator/>
                                <MenuItem Header="Close"    Tag="{Binding}" Click="ContextClose_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Right side: clock + power button -->
        <StackPanel Grid.Column="1" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="0,0,6,0">

            <TextBlock Name="ClockText"
                       Foreground="White"
                       FontSize="14"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Text="00:00:00"/>

            <Button Width="30" Height="30"
                    Background="#3A3A3A"
                    BorderBrush="#555"
                    BorderThickness="1"
                    Cursor="Hand"
                    ToolTip="Power options"
                    Click="PowerButton_Click">
                <Image Source="pack://application:,,,/Resources/power.ico"
                       Width="18" Height="18"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Shut Down..." Click="PowerShutdown_Click"/>
                        <MenuItem Header="Restart..."   Click="PowerRestart_Click"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </StackPanel>
    </Grid>
</Window>