<Window x:Class="ShellLauncher.UpdateSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShellLauncher - Update Settings"
        Width="560" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Update Settings" FontWeight="Bold" FontSize="16"
                   Margin="0,0,0,12"/>

        <!-- Installed version -->
        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Installed version:"
                   VerticalAlignment="Center" Margin="0,0,12,8"/>
        <TextBlock Grid.Row="1" Grid.Column="1"
                   x:Name="LblVersion"
                   VerticalAlignment="Center" FontStyle="Italic" Margin="0,0,0,8"/>

        <!-- GitHub Releases URL -->
        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="GitHub releases URL:"
                   VerticalAlignment="Center" Margin="0,0,12,12"/>
        <TextBox   Grid.Row="2" Grid.Column="1"
                   x:Name="TxtUrl"
                   VerticalAlignment="Center" Margin="0,0,0,12"/>

        <!-- Status -->
        <TextBlock Grid.Row="3" Grid.ColumnSpan="2"
                   x:Name="LblStatus"
                   TextWrapping="Wrap" MinHeight="20"
                   Margin="0,0,0,10"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal">
            <Button x:Name="BtnCheck"
                    Content="Check for Updates Now"
                    Width="180" Margin="0,0,10,0"
                    Click="CheckNow_Click"/>
            <Button x:Name="BtnSave"
                    Content="Save URL"
                    Width="100" Margin="0,0,10,0"
                    Click="Save_Click"/>
            <Button Content="Close"
                    Width="80"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>