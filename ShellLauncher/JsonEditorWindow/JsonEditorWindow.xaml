<Window x:Class="ShellLauncher.JsonEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit JSON Configuration" Height="450" Width="1150"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Applications" FontWeight="Bold" FontSize="16" Margin="0,0,0,6"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,2">
            <TextBlock Width="160" Margin="5,0" Text="Name"              FontWeight="SemiBold"/>
            <TextBlock Width="260" Margin="5,0" Text="Path"              FontWeight="SemiBold"/>
            <TextBlock Width="160" Margin="5,0" Text="Arguments"         FontWeight="SemiBold"/>
            <TextBlock Width="110" Margin="5,0" Text="Hide from Taskbar" FontWeight="SemiBold" TextWrapping="Wrap"/>
            <TextBlock Width="120" Margin="5,0" Text="Launch Mode"       FontWeight="SemiBold" TextWrapping="Wrap"/>
            <TextBlock Width="140" Margin="5,0" Text="Depends On (Name)" FontWeight="SemiBold" TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl Name="AppList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBox Width="160" Margin="5,0"
                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="WrapWithOverflow"
                                     VerticalScrollBarVisibility="Disabled"/>
                            <TextBox Width="260" Margin="5,0"
                                     Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="WrapWithOverflow"
                                     VerticalScrollBarVisibility="Disabled"/>
                            <TextBox Width="160" Margin="5,0"
                                     Text="{Binding Args, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="WrapWithOverflow"
                                     VerticalScrollBarVisibility="Disabled"/>
                            <CheckBox Width="110" Margin="10,0,0,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      IsChecked="{Binding ExcludeFromTaskbar, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding ExcludeFromTaskbarEnabled}"
                                      ToolTip="Not available when Launch Mode is NoLaunch - NoLaunch apps always appear in the taskbar"/>
                            <ComboBox Width="120" Margin="5,0"
                                      VerticalAlignment="Center"
                                      SelectedValue="{Binding LaunchMode, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Content"
                                      IsEnabled="{Binding LaunchModeEnabled}"
                                      ToolTip="Monitor=launch+restart, RunOnce=launch once, NoLaunch=taskbar only">
                                <ComboBoxItem Content="Monitor"  />
                                <ComboBoxItem Content="RunOnce"  />
                                <ComboBoxItem Content="NoLaunch" />
                            </ComboBox>
                            <TextBox Width="140" Margin="10,0,0,0"
                                     VerticalAlignment="Center"
                                     Text="{Binding DependsOn, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="WrapWithOverflow"
                                     VerticalScrollBarVisibility="Disabled"
                                     ToolTip="Enter the Name of another app that must be running before this one launches. Setting this disables Launch Mode."/>
                            <Button Content="X"
                                    Width="28" Height="28"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Top"
                                    Foreground="White"
                                    Background="#C0392B"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Tag="{Binding}"
                                    Click="RemoveApplication_Click"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Add Application"  Width="150" Margin="0,0,10,0" Click="AddApplication_Click"/>
            <Button Content="Save &amp; Exit"  Width="150" Margin="0,0,10,0" Click="SaveAndClose_Click"/>
            <Button Content="Save &amp; Launch" Width="150" Margin="0,0,10,0" Click="SaveAndLaunch_Click"/>
            <Button Content="Close All Apps"   Width="150" Margin="0,0,10,0" Click="CloseAllApps_Click"
                    Background="#C0392B" Foreground="White" BorderThickness="0"/>
            <Button Content="? Help"           Width="80"                    Click="Help_Click"/>
        </StackPanel>
    </Grid>
</Window>